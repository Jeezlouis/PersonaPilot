# ─────────────────────────────────────────────
#  JOB AUTOMATER — Environment Variables
# ─────────────────────────────────────────────

# === AI (Required) ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Telegram Bot (Required for notifications) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/job_automater.db

# === App Settings ===
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# === Job Search Preferences ===
# Comma-separated list of preferred locations (empty = any)
PREFERRED_LOCATIONS=Remote,Worldwide
# Min match score to surface in UI (0-100)
MIN_MATCH_SCORE=60
# Max applications per day (safety cap)
MAX_APPLICATIONS_PER_DAY=10
# Salary preference (USD, annual)
SALARY_MIN=50000
SALARY_MAX=200000

# === Scraping ===
# Comma-separated job titles to search for
SEARCH_KEYWORDS=Software Engineer,Frontend Developer,Backend Developer,Full Stack Developer,AI Engineer
# Request delay in seconds (be respectful)
SCRAPE_DELAY=2
# User-Agent string for scrapers
USER_AGENT=JobAutomater/1.0 (Personal job search tool)

# === Resume Storage ===
RESUME_DIR=./data/resumes

# === Application Settings ===
# "draft" = drafts only (safe). "email" = send via email
APPLICATION_MODE=draft

# === Email (Only if APPLICATION_MODE=email) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# === Platform Links (stored in DB, set via UI) ===
# These are defaults — update them in the Settings page
GITHUB_URL=https://github.com/yourusername
PORTFOLIO_URL=https://yourportfolio.com
LINKEDIN_URL=https://linkedin.com/in/yourprofile
